# =========================
# 主入口
# =========================

def main():
    ensure_base_dir()

    if len(sys.argv) > 1:
        cmd = sys.argv[1]
        if cmd == '--cron':
            check_cron_job()
            return
        if cmd == '--report':
            send_report_now()
            return
        if cmd == '--list-accounts':
            list_accounts_cli()
            return
        if cmd == '--account-count':
            account_count_cli()
            return
        if cmd == '--add-account':
            add_account_cli()
            return
        if cmd == '--delete-account':
            delete_account_cli()
            return
        if cmd == '--edit-account':
            edit_account_cli()
            return
        if cmd == '--enable-account':
            set_account_enabled_cli(True)
            return
        if cmd == '--disable-account':
            set_account_enabled_cli(False)
            return
        if cmd == '--enable-keepalive-account':
            set_account_keepalive_cli(True)
            return
        if cmd == '--disable-keepalive-account':
            set_account_keepalive_cli(False)
            return
        if cmd == '--status-account':
            status_account_cli()
            return
        if cmd == '--report-account':
            report_account_cli()
            return
        if cmd == '--start-account':
            start_account_cli()
            return
        if cmd == '--stop-account':
            stop_account_cli()
            return
        if cmd == '--cron-account':
            cron_account_cli()
            return
        if cmd == '--status-all':
            print(build_all_status_text())
            return

    if not os.path.exists(KEEPALIVE_FLAG_FILE):
        set_keepalive_enabled(True)

    accounts = load_accounts(include_disabled=True)
    if not accounts:
        logging.warning('暂无账号。请运行 cdt -> 多账号管理 -> 增加账号。')

    updater = Updater(
        TELEGRAM_BOT_TOKEN,
        workers=4,
        request_kwargs={'read_timeout': 10, 'connect_timeout': 10}
    )

    dispatcher = updater.dispatcher
    dispatcher.add_handler(CommandHandler('help', help_command))
    dispatcher.add_handler(CommandHandler('status', status_command))
    dispatcher.add_handler(CommandHandler('traffic', traffic_command))
    dispatcher.add_handler(CommandHandler('bill', bill_command))
    dispatcher.add_handler(CommandHandler('startvps', startvps_command))
    dispatcher.add_handler(CommandHandler('stopvps', stopvps_command))
    dispatcher.add_handler(CommandHandler('keepon', keepon_command))
    dispatcher.add_handler(CommandHandler('keepoff', keepoff_command))
    dispatcher.add_handler(CommandHandler('report', report_command))

    updater.start_polling(clean=True)
    logging.info('Telegram Bot 已启动：多账号模式，日报由 cron 按北京时间判断发送。')
    updater.idle()


if __name__ == '__main__':
    main()
