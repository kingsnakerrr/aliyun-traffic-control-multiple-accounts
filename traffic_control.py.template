LAST_NOTIFY_FILE = os.path.join(BASE_DIR, 'last_notify_state.json')

MONTHLY_RESET_OPEN_HOUR = 0
MONTHLY_RESET_OPEN_MINUTE = 5
DEFAULT_DAILY_REPORT_TIME = '09:00'
DEFAULT_MAX_TRAFFIC_GB = 180.0
DEFAULT_BILL_REGION_ID = 'cn-hangzhou'

