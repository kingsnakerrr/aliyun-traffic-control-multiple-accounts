def ensure_base_dir():
    os.makedirs(BASE_DIR, exist_ok=True)


def safe_float(value, default=DEFAULT_MAX_TRAFFIC_GB) -> float:
    try:
        return float(value)
    except Exception:
        return float(default)


def normalize_bool(value) -> bool:
    if isinstance(value, bool):
        return value
    return str(value).strip().lower() in ['1', 'true', 'yes', 'y', '是']


def account_key(account: Dict[str, Any]) -> str:
    raw = str(account.get('name') or account.get('instance_id') or 'account')
    key = re.sub(r'[^A-Za-z0-9_\-]+', '_', raw).strip('_')
    return key or 'account'


def account_name(account: Dict[str, Any]) -> str:
    return str(account.get('name') or account.get('instance_id') or '未命名账号')


def account_enabled(account: Dict[str, Any]) -> bool:
    return normalize_bool(account.get('enabled', True))


def load_accounts(include_disabled: bool = False) -> List[Dict[str, Any]]:
    if not os.path.exists(ACCOUNTS_FILE):
        return []
    try:
        with open(ACCOUNTS_FILE, 'r', encoding='utf-8') as f:
            data = json.load(f)
        if isinstance(data, dict) and 'accounts' in data:
            accounts = data.get('accounts') or []
        elif isinstance(data, list):
            accounts = data
        else:
            accounts = []
        normalized = []
        for acc in accounts:
            if not isinstance(acc, dict):
                continue
            acc.setdefault('enabled', True)
            acc.setdefault('bill_region_id', DEFAULT_BILL_REGION_ID)
            acc.setdefault('max_traffic_gb', DEFAULT_MAX_TRAFFIC_GB)
            acc.setdefault('daily_report_time', DEFAULT_DAILY_REPORT_TIME)
            acc.setdefault('is_international', False)
            if include_disabled or account_enabled(acc):
                normalized.append(acc)
        return normalized
    except Exception as e:
        logging.error(f'读取账号配置失败: {str(e)}')
        return []


def save_accounts(accounts: List[Dict[str, Any]]):
    ensure_base_dir()
    with open(ACCOUNTS_FILE, 'w', encoding='utf-8') as f:
        json.dump(accounts, f, ensure_ascii=False, indent=2)
    try:
        os.chmod(ACCOUNTS_FILE, 0o600)
    except Exception:
        pass


def find_account(selector: Optional[str], include_disabled: bool = False) -> Optional[Dict[str, Any]]:
    accounts = load_accounts(include_disabled=include_disabled)
    if not accounts:
        return None
    if not selector:
        return accounts[0]
    selector_s = str(selector).strip()
    if selector_s.isdigit():
        idx = int(selector_s) - 1
        if 0 <= idx < len(accounts):
            return accounts[idx]
    for acc in accounts:
        if account_name(acc) == selector_s or account_key(acc) == selector_s or str(acc.get('instance_id')) == selector_s:
            return acc
    return None


def validate_account(acc: Dict[str, Any]) -> List[str]:
    missing = []
    for field in ['name', 'access_key_id', 'access_key_secret', 'region_id', 'instance_id']:
        if not str(acc.get(field) or '').strip():
            missing.append(field)
    return missing

