def prompt(msg: str, default: Optional[str] = None, secret: bool = False) -> str:
    # secret 保留参数，避免额外依赖 getpass；root 终端录入简单直接。
    if default is None or default == '':
        val = input(f'{msg}: ').strip()
    else:
        val = input(f'{msg}，默认 {default}: ').strip()
        if not val:
            val = default
    return val


def prompt_bool(msg: str, default: bool = False) -> bool:
    suffix = '默认 y' if default else '默认 n'
    val = input(f'{msg}，输入 y/n，{suffix}: ').strip().lower()
    if not val:
        return default
    return val in ['y', 'yes', '1', 'true', '是']


def build_account_from_prompt(existing: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:
    existing = existing or {}
    acc = dict(existing)
    acc['name'] = prompt('账号显示名称，例如 zymsdf-香港', existing.get('name', 'zymsdf'))
    acc['access_key_id'] = prompt('阿里云 ACCESS_KEY_ID', existing.get('access_key_id'))
    acc['access_key_secret'] = prompt('阿里云 ACCESS_KEY_SECRET', existing.get('access_key_secret'))
    acc['region_id'] = prompt('ECS 区域，例如 cn-hongkong', existing.get('region_id', 'cn-hongkong'))
    acc['instance_id'] = prompt('ECS 实例 ID', existing.get('instance_id'))
    acc['bill_region_id'] = prompt('账单接口区域', existing.get('bill_region_id', DEFAULT_BILL_REGION_ID))
    acc['max_traffic_gb'] = safe_float(prompt('流量阈值 GB', str(existing.get('max_traffic_gb', DEFAULT_MAX_TRAFFIC_GB))))
    acc['is_international'] = prompt_bool('是否国际版账号', normalize_bool(existing.get('is_international', False)))
    report_default = existing.get('daily_report_time', DEFAULT_DAILY_REPORT_TIME)
    report_time = prompt('每天日报推送时间 HH:MM，固定按北京时间 UTC+8', report_default)
    if not re.match(r'^([01][0-9]|2[0-3]):[0-5][0-9]$', report_time):
        print('日报时间格式错误，已使用 09:00')
        report_time = DEFAULT_DAILY_REPORT_TIME
    acc['daily_report_time'] = report_time
    acc['auto_keepalive'] = prompt_bool('是否开启这个账号自动保活', account_keepalive_enabled(acc))
    acc['enabled'] = prompt_bool('是否启用这个账号', normalize_bool(existing.get('enabled', True)))
    return acc


def list_accounts_cli():
    accounts = load_accounts(include_disabled=True)
    if not accounts:
        print('暂无账号。')
        return
    print('===== 账号列表 =====')

    # cdt 首页只显示账号列表，不把阿里云 SDK 的完整错误日志喷到屏幕。
    # 例如乱填 AccessKey 测试时，只显示“状态未知：Unknown”。
    old_disable_level = logging.root.manager.disable
    logging.disable(logging.CRITICAL)
    try:
        for i, acc in enumerate(accounts, start=1):
            enabled = '启用' if account_enabled(acc) else '禁用'
            intl = '国际版' if normalize_bool(acc.get('is_international')) else '国内版'
            keep = '保活开' if account_keepalive_enabled(acc) else '保活关'
            instance_status = get_vps_status(acc)
            runtime = account_runtime_status(acc, instance_status)
            print(f'{i}. {account_name(acc)} | {runtime} | {enabled} | {keep} | {intl} | {acc.get("region_id")} | {acc.get("instance_id")} | 阈值 {max_gb(acc):g}GB | 日报 {acc.get("daily_report_time")} UTC+8')
    finally:
        logging.disable(old_disable_level)


def add_account_cli():
    accounts = load_accounts(include_disabled=True)
    print('请按提示录入新账号。不同阿里云账号要填各自的 AccessKey。')
    acc = build_account_from_prompt()
    missing = validate_account(acc)
    if missing:
        print('配置缺少字段：' + ', '.join(missing))
        return
    accounts.append(acc)
    save_accounts(accounts)
    print(f'✅ 已增加账号：{account_name(acc)}')


def account_count_cli():
    print(len(load_accounts(include_disabled=True)))


def account_selector_from_argv(default_prompt='请输入账号序号或名称: '):
    if len(sys.argv) >= 3 and str(sys.argv[2]).strip():
        return str(sys.argv[2]).strip()
    list_accounts_cli()
    accounts = load_accounts(include_disabled=True)
    if not accounts:
        return None
    return input(default_prompt).strip()


def delete_account_cli():
    accounts = load_accounts(include_disabled=True)
    if not accounts:
        print('暂无账号。')
        return
    val = account_selector_from_argv('请输入要删除的账号序号或名称: ')
    if not val:
        return
    acc = find_account(val, include_disabled=True)
    if not acc:
        print('没有找到这个账号。')
        return
    confirm = input(f'确定删除账号 {account_name(acc)}？输入 yes 继续: ').strip()
    if confirm != 'yes':
        print('已取消。')
        return
    accounts = [a for a in accounts if account_key(a) != account_key(acc)]
    save_accounts(accounts)
    clear_account_notify_state(acc)
    print(f'✅ 已删除账号：{account_name(acc)}')


def edit_account_cli():
    accounts = load_accounts(include_disabled=True)
    if not accounts:
        print('暂无账号。')
        return
    val = account_selector_from_argv('请输入要编辑的账号序号或名称: ')
    if not val:
        return
    target = find_account(val, include_disabled=True)
    if not target:
        print('没有找到这个账号。')
        return
    old_key = account_key(target)
    new_acc = build_account_from_prompt(target)
    new_accounts = []
    for acc in accounts:
        if account_key(acc) == old_key:
            new_accounts.append(new_acc)
        else:
            new_accounts.append(acc)
    save_accounts(new_accounts)
    print(f'✅ 已更新账号：{account_name(new_acc)}')


def set_account_enabled_cli(enabled: bool):
    accounts = load_accounts(include_disabled=True)
    if not accounts:
        print('暂无账号。')
        return
    val = account_selector_from_argv('请输入账号序号或名称: ')
    if not val:
        return
    target = find_account(val, include_disabled=True)
    if not target:
        print('没有找到这个账号。')
        return
    target_key = account_key(target)
    for acc in accounts:
        if account_key(acc) == target_key:
            acc['enabled'] = enabled
            break
    save_accounts(accounts)
    print(f'✅ 已{"启用" if enabled else "禁用"}账号：{account_name(target)}')


def set_account_keepalive_cli(enabled: bool):
    accounts = load_accounts(include_disabled=True)
    if not accounts:
        print('暂无账号。')
        return
    val = account_selector_from_argv('请输入账号序号或名称: ')
    if not val:
        return
    target = find_account(val, include_disabled=True)
    if not target:
        print('没有找到这个账号。')
        return
    target_key = account_key(target)
    for acc in accounts:
        if account_key(acc) == target_key:
            acc['auto_keepalive'] = enabled
            break
    save_accounts(accounts)
    clear_notify_key(target, 'keepalive_action')
    clear_notify_key(target, 'keepalive_failed')
    clear_pending_keepalive(target)
    print(f'✅ 已{"开启" if enabled else "关闭"}账号自动保活：{account_name(target)}')


