# =========================
# 时间：全部按北京时间 UTC+8
# =========================
CN_TZ = timezone(timedelta(hours=8))


def now_cn():
    return datetime.now(CN_TZ)


def now_text():
    return now_cn().strftime('%Y-%m-%d %H:%M:%S UTC+8')


def today_cn_str():
    return now_cn().strftime('%Y-%m-%d')


def get_billing_cycle():
    return now_cn().strftime('%Y-%m')


def get_report_hour_minute(account: Dict[str, Any]) -> Tuple[int, int]:
    report_time = str(account.get('daily_report_time') or DEFAULT_DAILY_REPORT_TIME)
    try:
        hour_s, minute_s = report_time.strip().split(':', 1)
        return int(hour_s), int(minute_s)
    except Exception:
        return 9, 0


def is_daily_report_time(account: Dict[str, Any]) -> bool:
    hour, minute = get_report_hour_minute(account)
    now = now_cn()
    return now.hour == hour and now.minute == minute


def is_month_reset_open_window() -> bool:
    now = now_cn()
    return now.day == 1 and (
        now.hour > MONTHLY_RESET_OPEN_HOUR or
        (now.hour == MONTHLY_RESET_OPEN_HOUR and now.minute >= MONTHLY_RESET_OPEN_MINUTE)
    )


def get_next_cdt_reset_check_time() -> str:
    now = now_cn()
    if now.month == 12:
        nxt = datetime(now.year + 1, 1, 1, MONTHLY_RESET_OPEN_HOUR, MONTHLY_RESET_OPEN_MINUTE, 0, tzinfo=CN_TZ)
    else:
        nxt = datetime(now.year, now.month + 1, 1, MONTHLY_RESET_OPEN_HOUR, MONTHLY_RESET_OPEN_MINUTE, 0, tzinfo=CN_TZ)
    return nxt.strftime('%Y-%m-%d %H:%M:%S UTC+8')

# =========================
