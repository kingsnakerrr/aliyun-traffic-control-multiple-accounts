def get_cdt_traffic(account: Dict[str, Any]) -> float:
    request = CommonRequest()
    request.set_domain('cdt.aliyuncs.com')
    request.set_version('2021-08-13')
    request.set_action_name('ListCdtInternetTraffic')
    request.set_method('POST')
    try:
        response = ecs_client(account).do_action_with_exception(request)
        response_json = json.loads(response.decode('utf-8'))
        total_bytes = sum(d.get('Traffic', 0) for d in response_json.get('TrafficDetails', []))
        return round(total_bytes / (1024 ** 3), 2)
    except Exception as e:
        logging.error(f'[{account_name(account)}] CDT流量查询失败: {str(e)}')
        return 0.0


def get_aliyun_data(account: Dict[str, Any]) -> str:
    try:
        balance = '0.00'
        request_bal = QueryAccountBalanceRequest.QueryAccountBalanceRequest()
        request_bal.set_accept_format('json')
        res_bal = bill_client(account).do_action_with_exception(request_bal)
        data_bal = json.loads(res_bal.decode('utf-8'))
        if data_bal.get('Success'):
            balance = data_bal.get('Data', {}).get('AvailableAmount', '0.00')

        request_bill = QueryBillOverviewRequest.QueryBillOverviewRequest()
        request_bill.set_accept_format('json')
        request_bill.set_BillingCycle(get_billing_cycle())
        res_bill = bill_client(account).do_action_with_exception(request_bill)
        data_bill = json.loads(res_bill.decode('utf-8'))
        cost = 0.0
        if data_bill.get('Success') and data_bill.get('Data'):
            items = data_bill.get('Data', {}).get('Items', {}).get('Item', [])
            cost = sum(float(item.get('PretaxAmount', 0)) for item in items)

        if normalize_bool(account.get('is_international')):
            return f'💳 扣费方式：国际站后付费\n💵 本月消费（1号至今）：${cost:.2f}'
        return f'💰 账户现金余额：{balance} 元\n💵 本月消费（1号至今）：{cost:.2f} 元'
    except Exception as e:
        logging.error(f'[{account_name(account)}] 查询余额/账单失败: {str(e)}')
        if normalize_bool(account.get('is_international')):
            return '💳 扣费方式：国际站后付费\n💵 本月消费（1号至今）：$0.00'
        return '💰 账户现金余额：暂无数据\n💵 本月消费（1号至今）：0.00 元'

