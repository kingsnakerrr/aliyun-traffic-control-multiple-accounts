def send_tg(chat_id, text, parse_mode=None):
    try:
        data = {'chat_id': chat_id, 'text': text}
        if parse_mode:
            data['parse_mode'] = parse_mode
        res = requests.post(
            f'https://api.telegram.org/bot{TELEGRAM_BOT_TOKEN}/sendMessage',
            data=data,
            timeout=10
        )
        if not res.ok:
            logging.error(f'TG发送失败: {res.text}')
            return False
        return True
    except Exception as e:
        logging.error(f'发送TG失败: {str(e)}')
        return False


def is_admin(update: Update):
    user_id = update.effective_user.id if update.effective_user else None
    return str(user_id) == str(ADMIN_USER_ID)


def get_chat_id(update: Update):
    return update.effective_chat.id if update.effective_chat else ADMIN_USER_ID


def load_notify_state():
    try:
        if not os.path.exists(LAST_NOTIFY_FILE):
            return {}
        with open(LAST_NOTIFY_FILE, 'r', encoding='utf-8') as f:
            return json.load(f)
    except Exception:
        return {}


def save_notify_state(state):
    try:
        ensure_base_dir()
        with open(LAST_NOTIFY_FILE, 'w', encoding='utf-8') as f:
            json.dump(state, f, ensure_ascii=False, indent=2)
    except Exception as e:
        logging.error(f'保存通知状态失败: {str(e)}')


def scoped_key(account: Dict[str, Any], suffix: str) -> str:
    return f'{account_key(account)}::{suffix}'


def notify_once(account: Dict[str, Any], suffix: str, text: str):
    key = scoped_key(account, suffix)
    state = load_notify_state()
    if state.get(key):
        return False
    if send_tg(TELEGRAM_CHAT_ID, text):
        state[key] = now_text()
        save_notify_state(state)
        return True
    return False


def clear_notify_key(account: Dict[str, Any], suffix: str):
    key = scoped_key(account, suffix)
    state = load_notify_state()
    if key in state:
        del state[key]
        save_notify_state(state)


def has_notify_key(account: Dict[str, Any], suffix: str) -> bool:
    return bool(load_notify_state().get(scoped_key(account, suffix)))


def clear_account_notify_state(account: Dict[str, Any]):
    prefix = f'{account_key(account)}::'
    state = load_notify_state()
    new_state = {k: v for k, v in state.items() if not k.startswith(prefix)}
    if len(new_state) != len(state):
        save_notify_state(new_state)


def set_pending_keepalive(account: Dict[str, Any], status: str):
    state = load_notify_state()
    state[scoped_key(account, 'keepalive_pending')] = {'time': now_text(), 'status': status}
    save_notify_state(state)


def get_pending_keepalive(account: Dict[str, Any]):
    return load_notify_state().get(scoped_key(account, 'keepalive_pending'))


def clear_pending_keepalive(account: Dict[str, Any]):
    clear_notify_key(account, 'keepalive_pending')

