# =========================

def maybe_send_daily_report(account):
    if is_daily_report_time(account):
        suffix = f'daily_report_{today_cn_str()}'
        if notify_once(account, suffix, build_status_text(account)):
            logging.info(f'[{account_name(account)}] 已发送每日 {account.get("daily_report_time")} 北京时间报告到频道。')
    else:
        state = load_notify_state()
        prefix = f'{account_key(account)}::daily_report_'
        today_key = scoped_key(account, f'daily_report_{today_cn_str()}')
        old_keys = [k for k in state if k.startswith(prefix) and k != today_key]
        if old_keys:
            for key in old_keys:
                del state[key]
            save_notify_state(state)


def check_one_account(account: Dict[str, Any]):
    missing = validate_account(account)
    if missing:
        logging.error(f'[{account_name(account)}] 账号配置缺少字段: {", ".join(missing)}')
        return

    maybe_send_daily_report(account)

    traffic = get_cdt_traffic(account)
    status_before = get_vps_status(account)
    status_l = status_before.lower()
    logging.info(f'[{account_name(account)}] cron检查：流量 {traffic} GB / {max_gb(account):g} GB，实例状态 {status_before}')

    if now_cn().day != 1:
        clear_notify_key(account, 'monthly_reset_start')

    if traffic >= max_gb(account):
        clear_notify_key(account, 'manual_stop')
        ok, result = stop_vps_safety(account)
        logging.warning(f'[{account_name(account)}] {result}')
        notify_once(account, 'traffic_stop', build_traffic_stop_notice(account, traffic, result))
        return

    if not account_keepalive_enabled(account):
        logging.info(f'[{account_name(account)}] 这个账号的自动保活已关闭，跳过自动开机。')
        clear_notify_key(account, 'keepalive_failed')
        return

    traffic_stopped = has_notify_key(account, 'traffic_stop')
    if traffic_stopped:
        if not is_month_reset_open_window():
            logging.info(f'[{account_name(account)}] 此前因流量熔断关机，未到每月1号00:05 UTC+8，暂不自动开机。')
            return
        ok, result = start_vps_safety(account)
        logging.info(f'[{account_name(account)}] {result}')
        if ok:
            notify_once(account, 'monthly_reset_start', build_monthly_reset_start_notice(account, traffic, result))
            clear_notify_key(account, 'traffic_stop')
            set_pending_keepalive(account, status_before)
        else:
            notify_once(account, 'keepalive_failed', (
                f'〖月初自动开机失败〗\n\n账号：{account_name(account)}\n'
                f'当前 CDT 流量：{traffic} GB / {max_gb(account):g} GB\n'
                f'失败原因：{result}\n\n请检查余额、实例状态、阿里云风控或实例是否已释放。\n'
                f'实例：{account.get("instance_id")}\n时间：{now_text()}'
            ))
        return

    if status_l == 'running':
        pending = get_pending_keepalive(account)
        if pending:
            old_status = pending.get('status', 'Unknown')
            send_tg(TELEGRAM_CHAT_ID, build_keepalive_success_notice(account, old_status, traffic))
            clear_pending_keepalive(account)
            clear_notify_key(account, 'keepalive_action')
            clear_notify_key(account, 'keepalive_failed')
        logging.info(f'[{account_name(account)}] 实例 Running，保活正常。')
        return

    if status_l in ['starting', 'stopping']:
        set_pending_keepalive(account, status_before)
        logging.info(f'[{account_name(account)}] 实例状态 {status_before}，等待状态稳定。')
        return

    ok, result = start_vps_safety(account)
    logging.info(f'[{account_name(account)}] {result}')
    set_pending_keepalive(account, status_before)
    if ok:
        notify_once(account, 'keepalive_action', build_keepalive_action_notice(account, status_before, result, traffic))
    else:
        notify_once(account, 'keepalive_failed', (
            f'〖保活启动失败〗\n\n账号：{account_name(account)}\n'
            f'检测到实例状态：{status_before}\n'
            f'当前 CDT 流量：{traffic} GB / {max_gb(account):g} GB\n'
            f'失败原因：{result}\n\n请检查余额、实例状态、阿里云风控或实例是否已释放。\n'
            f'实例：{account.get("instance_id")}\n时间：{now_text()}'
        ))


def check_cron_job():
    accounts = load_accounts(include_disabled=False)
    if not accounts:
        logging.warning('没有启用的账号，跳过 cron。')
        return
    for account in accounts:
        try:
            check_one_account(account)
        except Exception as e:
            logging.error(f'[{account_name(account)}] cron处理失败: {str(e)}')

