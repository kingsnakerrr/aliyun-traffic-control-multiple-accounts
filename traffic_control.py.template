def max_gb(account: Dict[str, Any]) -> float:
    return safe_float(account.get('max_traffic_gb'), DEFAULT_MAX_TRAFFIC_GB)


def account_runtime_status(account: Dict[str, Any], instance_status: Optional[str] = None) -> str:
    """给 cdt 首页和通知用的人话状态。
    traffic_stop/manual_stop 只记录本程序触发的原因；如果用户在阿里云后台关机，显示为未知原因关机。
    """
    if instance_status is None:
        instance_status = get_vps_status(account)
    status_l = str(instance_status or 'Unknown').lower()

    if status_l == 'running':
        return '机器在线运行中'
    if status_l == 'starting':
        return '正在开机中'
    if status_l == 'stopping':
        return '正在关机中'
    if has_notify_key(account, 'traffic_stop'):
        return '流量达到阈值已关机'
    if has_notify_key(account, 'manual_stop'):
        return '手动关机'
    if status_l == 'stopped':
        if not account_keepalive_enabled(account):
            return '已关机（保活关闭）'
        return '已关机（外部/未知原因）'
    return f'状态未知：{instance_status}'


def build_status_text(account: Dict[str, Any]) -> str:
    traffic = get_cdt_traffic(account)
    instance_status = get_vps_status(account)
    runtime_status = account_runtime_status(account, instance_status)
    financial_info = get_aliyun_data(account)
    keep_status = '正常' if account_keepalive_enabled(account) else '已暂停'
    enabled_text = '启用' if account_enabled(account) else '已禁用'
    return (
        f'📊 阿里云账号 {account_name(account)} - CDT服务器\n\n'
        '----------------------------------\n'
        f'⏰ 时间：{now_text()}\n'
        f'📡 当前流量：{traffic} GB / {max_gb(account):g} GB\n'
        f'🖥 实例状态：{instance_status}\n'
        f'📌 当前状态：{runtime_status}\n'
        f'🌍 ECS区域：{account.get("region_id")}\n'
        f'🆔 实例：{account.get("instance_id")}\n'
        f'{financial_info}\n'
        f'⚡ 保活运行状态：{keep_status}\n'
        f'🔘 账号状态：{enabled_text}\n'
        f'📅 下次自动检测开机：{get_next_cdt_reset_check_time()}\n'
        '✅ 流量控制脚本运行正常\n'
        '----------------------------------'
    )


def build_all_status_text() -> str:
    accounts = load_accounts(include_disabled=True)
    if not accounts:
        return '❌ 暂无账号，请先用 cdt -> 多账号管理 -> 增加账号。'
    parts = [build_status_text(acc) for acc in accounts]
    return '\n\n'.join(parts)


