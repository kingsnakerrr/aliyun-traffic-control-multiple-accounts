def keepalive_enabled():
    return os.path.exists(KEEPALIVE_FLAG_FILE)


def set_keepalive_enabled(enabled: bool):
    ensure_base_dir()
    if enabled:
        with open(KEEPALIVE_FLAG_FILE, 'w', encoding='utf-8') as f:
            f.write('enabled\n')
    else:
        if os.path.exists(KEEPALIVE_FLAG_FILE):
            os.remove(KEEPALIVE_FLAG_FILE)


def account_keepalive_enabled(account: Dict[str, Any]) -> bool:
    """账号级自动保活开关。
    兼容旧版本：如果账号里没有 auto_keepalive 字段，默认开启。
    说明：现在 cdt 菜单按账号单独控制保活；全局 flag 仅保留给旧版本兼容，
    不再影响单个账号的启停判断。
    """
    return normalize_bool(account.get('auto_keepalive', True))

