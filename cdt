#!/usr/bin/env bash
set -e

BASE_DIR="/root/aliyun-traffic-control"
SERVICE_NAME="traffic-control.service"
PY="${BASE_DIR}/venv/bin/python"
APP="${BASE_DIR}/traffic_control.py"
ACCOUNTS_FILE="${BASE_DIR}/accounts.json"

need_root(){ [ "$(id -u)" -eq 0 ] || { echo "请使用 root 用户运行"; exit 1; }; }
pause(){ echo; read -r -p "按回车返回菜单..."; }
run_app(){ "$PY" "$APP" "$@"; }
service_status(){ systemctl status "$SERVICE_NAME" -l --no-pager || true; }
start_bot(){ systemctl start "$SERVICE_NAME"; echo "已启动 TG Bot 服务"; }
stop_bot(){ systemctl stop "$SERVICE_NAME"; echo "已停止 TG Bot 服务"; }
restart_bot(){ systemctl restart "$SERVICE_NAME"; echo "已重启 TG Bot 服务"; }
enable_keepalive(){ touch "${BASE_DIR}/keepalive_enabled.flag"; echo "已开启全局自动保活"; }
disable_keepalive(){ rm -f "${BASE_DIR}/keepalive_enabled.flag"; echo "已关闭全局自动保活"; }
restart_keepalive(){ touch "${BASE_DIR}/keepalive_enabled.flag"; run_app --cron; echo "已执行一次多账号保活检查"; }
send_report_now(){ run_app --report; echo "已立即发送所有账号日报到频道"; }
show_last_logs(){ echo "===== cron_run.log 最近40行 ====="; tail -n 40 "${BASE_DIR}/cron_run.log" 2>/dev/null || echo "暂无 cron_run.log"; echo; echo "===== systemd 最近30行 ====="; journalctl -u "$SERVICE_NAME" -n 30 --no-pager || true; }
live_logs(){ echo "实时日志：Ctrl+C 退出"; touch "${BASE_DIR}/cron_run.log"; tail -n 30 -f "${BASE_DIR}/cron_run.log"; }
show_crontab(){ echo "===== 当前 root crontab ====="; crontab -l 2>/dev/null || echo "当前没有 crontab"; }
show_time(){ echo "===== 当前系统时间 ====="; date; echo; timedatectl 2>/dev/null || true; echo; echo "说明：程序内部日报和月初恢复固定使用 UTC+8 / 北京时间。"; }
show_notify_state(){ echo "===== 通知状态文件 ====="; cat "${BASE_DIR}/last_notify_state.json" 2>/dev/null || echo "暂无通知状态文件"; }
show_accounts_json(){ echo "===== accounts.json ====="; cat "$ACCOUNTS_FILE" 2>/dev/null || echo "暂无账号配置"; }
edit_accounts_json(){ ${EDITOR:-nano} "$ACCOUNTS_FILE"; echo "修改完成后建议重启服务：systemctl restart traffic-control"; }
edit_config(){ ${EDITOR:-nano} "$APP"; echo "修改完成后建议重启服务：systemctl restart traffic-control"; }
backup_accounts(){ cp -a "$ACCOUNTS_FILE" "${ACCOUNTS_FILE}.bak.$(date +%Y%m%d%H%M%S)" 2>/dev/null || true; echo "已备份 accounts.json 到同目录 .bak 文件"; }
uninstall_all(){ echo "即将完全卸载程序"; read -r -p "确定卸载？输入 yes 继续: " ans; [ "$ans" = "yes" ] || { echo "已取消"; return; }; systemctl stop "$SERVICE_NAME" 2>/dev/null || true; systemctl disable "$SERVICE_NAME" 2>/dev/null || true; rm -f "/etc/systemd/system/${SERVICE_NAME}"; systemctl daemon-reload || true; crontab -l 2>/dev/null | grep -v "aliyun-traffic-control/traffic_control.py" | crontab - || true; rm -f /usr/local/bin/cdt; rm -rf "$BASE_DIR"; echo "卸载完成"; exit 0; }

accounts_menu(){
  while true; do
    clear
    echo "=============================="
    echo " 多账号管理"
    echo "=============================="
    echo "1. 查看账号列表"
    echo "2. 增加账号"
    echo "3. 删除账号"
    echo "4. 编辑账号"
    echo "5. 启用账号"
    echo "6. 禁用账号"
    echo "7. 查看 accounts.json"
    echo "8. 手动编辑 accounts.json"
    echo "9. 备份 accounts.json"
    echo "0. 返回主菜单"
    echo "=============================="
    read -r -p "请输入选项: " c
    case "$c" in
      1) run_app --list-accounts; pause;;
      2) run_app --add-account; restart_bot; pause;;
      3) run_app --delete-account; restart_bot; pause;;
      4) run_app --edit-account; restart_bot; pause;;
      5) run_app --enable-account; restart_bot; pause;;
      6) run_app --disable-account; restart_bot; pause;;
      7) show_accounts_json; pause;;
      8) backup_accounts; edit_accounts_json; restart_bot; pause;;
      9) backup_accounts; pause;;
      0) return;;
      *) echo "无效选项"; pause;;
    esac
  done
}

menu(){
  clear
  echo "=============================="
  echo " 阿里云 CDT 流量控制菜单（多账号版）"
  echo "=============================="
  echo "1. 查看服务状态"
  echo "2. 启动 TG Bot 服务"
  echo "3. 停止 TG Bot 服务"
  echo "4. 重启 TG Bot 服务"
  echo "5. 开启全局自动保活"
  echo "6. 关闭全局自动保活"
  echo "7. 重启/立即执行一次保活检查"
  echo "8. 立即发送所有账号日报到频道（测试）"
  echo "9. 查看最近日志"
  echo "10. 查看实时 cron 日志"
  echo "11. 查看当前 crontab"
  echo "12. 编辑主程序文件"
  echo "13. 查看系统时间/时区"
  echo "14. 查看通知状态文件"
  echo "15. 多账号管理"
  echo "16. 完全卸载程序"
  echo "0. 退出"
  echo "=============================="
}

main(){
  need_root
  while true; do
    menu
    read -r -p "请输入选项: " choice
    case "$choice" in
      1) service_status; pause;;
      2) start_bot; pause;;
      3) stop_bot; pause;;
      4) restart_bot; pause;;
      5) enable_keepalive; pause;;
      6) disable_keepalive; pause;;
      7) restart_keepalive; pause;;
      8) send_report_now; pause;;
      9) show_last_logs; pause;;
      10) live_logs; pause;;
      11) show_crontab; pause;;
      12) edit_config; pause;;
      13) show_time; pause;;
      14) show_notify_state; pause;;
      15) accounts_menu;;
      16) uninstall_all;;
      0) exit 0;;
      *) echo "无效选项"; pause;;
    esac
  done
}

main "$@"
